# Model names (Ollama format)
EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest
LLM_MODEL=gemma4:12b-it-q4_K_M

# Absolute path to the ChromaDB persistence directory.
# Use an absolute path to avoid cwd-dependent behavior across environments.
# Local example:  CHROMA_PERSIST_DIR=/path/to/reliablerag/data/chroma_db
# Colab example:  CHROMA_PERSIST_DIR=/content/data/chroma_db
CHROMA_PERSIST_DIR=/absolute/path/to/data/chroma_db